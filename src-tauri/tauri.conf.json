{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Notker",
  "version": "0.0.2-alpha",
  "identifier": "br.org.aiscgre.notker",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [{ "label": "main", "title": "Notker", "width": 1100, "height": 740 }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/gregorio-lsp"],
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "10.15"
    }
  }
}
