{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Notker",
  "version": "0.0.3-alpha",
  "identifier": "br.org.aiscgre.notker",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [{ "label": "main", "title": "Notker", "width": 1100, "height": 740 }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/gregorio-lsp"],
    "linux": {
      "rpm": { "depends": ["webkit2gtk4.1", "gtk3"] }
    },
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "10.15"
    }
  }
}
